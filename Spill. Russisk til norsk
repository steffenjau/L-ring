<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8">
<title>Norsk Spill 🎉</title>
<style>
    body {
        font-family: Arial;
        text-align: center;
        background: linear-gradient(to right, #87CEFA, #FFD700);
    }
    .card {
        background: white;
        padding: 20px;
        margin: 20px auto;
        width: 300px;
        border-radius: 15px;
        box-shadow: 0 0 10px gray;
    }
    button {
        padding: 10px;
        margin: 5px;
        font-size: 16px;
        border-radius: 10px;
        cursor: pointer;
    }
    .correct {
        background-color: lightgreen;
    }
    .wrong {
        background-color: lightcoral;
    }
</style>
</head>
<body>

<h1>🎮 Lær Norsk!</h1>
<p>Velg riktig norsk ord!</p>

<div class="card">
    <h2 id="russianWord">кошка</h2>
    <button onclick="checkAnswer('katt')">katt</button>
    <button onclick="checkAnswer('hund')">hund</button>
    <button onclick="checkAnswer('hus')">hus</button>
</div>

<h3>Poeng: <span id="score">0</span></h3>

<audio id="correctSound" src="https://www.soundjay.com/buttons/sounds/button-3.mp3"></audio>
<audio id="wrongSound" src="https://www.soundjay.com/buttons/sounds/button-10.mp3"></audio>

<script>
let score = 0;

const words = [
    {ru: "кошка", no: "katt", options: ["katt", "hund", "hus"]},
    {ru: "собака", no: "hund", options: ["katt", "bil", "hund"]},
    {ru: "дом", no: "hus", options: ["hus", "bok", "vann"]},
    {ru: "вода", no: "vann", options: ["mat", "vann", "sol"]},
];

let current = 0;

function loadWord() {
    let w = words[current];
    document.getElementById("russianWord").innerText = w.ru;

    let buttons = document.querySelectorAll("button");
    w.options.forEach((opt, i) => {
        buttons[i].innerText = opt;
        buttons[i].className = "";
    });
}

function checkAnswer(answer) {
    let correct = words[current].no;

    if (answer === correct) {
        score++;
        document.getElementById("correctSound").play();
        flashColor("correct");
    } else {
        document.getElementById("wrongSound").play();
        flashColor("wrong");
    }

    document.getElementById("score").innerText = score;

    current = (current + 1) % words.length;
    setTimeout(loadWord, 1000);
}

function flashColor(type) {
    document.body.style.background = type === "correct" ? "lightgreen" : "lightcoral";
    setTimeout(() => {
        document.body.style.background = "linear-gradient(to right, #87CEFA, #FFD700)";
    }, 500);
}

loadWord();
</script>

</body>
</html>
